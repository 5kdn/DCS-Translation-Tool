<Page x:Class="DcsTranslationTool.Presentation.Wpf.Features.Settings.SettingsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
      xmlns:resx="clr-namespace:DcsTranslationTool.Resources;assembly=DcsTranslationTool.Resources"
      xmlns:local="clr-namespace:DcsTranslationTool.Presentation.Wpf.Features.Settings"
      xmlns:common="clr-namespace:DcsTranslationTool.Presentation.Wpf.Features.Common"
      xmlns:cal="http://www.caliburnproject.org"
      mc:Ignorable="d"
      d:DesignHeight="1950" d:DesignWidth="400">


    <ScrollViewer>
        <Grid Margin="{StaticResource SmallXMargin}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBlock Style="{StaticResource MaterialDesignDisplayLargeTextBlock}"
                       Text="{x:Static resx:Strings_Settings.Title}"
                       Margin="{StaticResource MediumBottomMargin}" />

            <StackPanel x:Name="ContentArea" Grid.Row="1">

                <!-- フォルダー設定 -->
                <StackPanel>
                    <TextBlock Text="{x:Static resx:Strings_Settings.DirectorySettingsTitle}"
                               Style="{StaticResource MaterialDesignHeadlineMediumTextBlock}" />

                    <TextBlock Margin="{StaticResource SmallTopMargin}"
                               Text="{x:Static resx:Strings_Settings.DcsWorldSectionTitle}"
                               Style="{StaticResource MaterialDesignHeadlineSmallTextBlock}" />

                    <TextBlock Margin="{StaticResource SmallTopMargin}"
                               Text="{x:Static resx:Strings_Settings.DcsWorldInstallDirText}"
                               Style="{StaticResource MaterialDesignHeadlineSmallTextBlock}" />
                    <TextBlock Margin="{StaticResource XSmallTopMargin}"
                               Text="{x:Static resx:Strings_Settings.DcsWorldInstallDirExplanationText}"
                               TextWrapping="Wrap"
                               Style="{StaticResource MaterialDesignBodySmallTextBlock}" />
                    <common:DirectoryPicker
                                            Path="{Binding DcsWorldInstallDir, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            Key="DcsWorldInstall"
                                            ButtonText="{x:Static resx:Strings_Settings.SelectButton}"
                                            Margin="{StaticResource MediumBottomMargin}"/>

                    <TextBlock Text="{x:Static resx:Strings_Settings.SourceUserMissionDirText}"
                               Style="{StaticResource MaterialDesignHeadlineSmallTextBlock}" />
                    <TextBlock Margin="{StaticResource XSmallTopMargin}"
                               Text="{x:Static resx:Strings_Settings.SourceUserMissionDirExplanationText}"
                               TextWrapping="Wrap"
                               Style="{StaticResource MaterialDesignBodySmallTextBlock}" />
                    <common:DirectoryPicker
                                            Path="{Binding SourceUserMissionDir, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            Key="UserMission"
                                            ButtonText="{x:Static resx:Strings_Settings.SelectButton}"
                                            Margin="{StaticResource MediumBottomMargin}" />

                    <TextBlock Margin="{StaticResource MediumTopMargin}"
                               Text="{x:Static resx:Strings_Settings.ExternalInjectionTitle}"
                               Style="{StaticResource MaterialDesignHeadlineSmallTextBlock}" />
                    <TextBlock Margin="{StaticResource XSmallTopMargin}"
                               Text="{x:Static resx:Strings_Settings.ExternalInjectionDescription}"
                               TextWrapping="Wrap"
                               Style="{StaticResource MaterialDesignBodySmallTextBlock}" />

                    <CheckBox Margin="0,8,0,0"
                              Padding="0"
                              VerticalContentAlignment="Center"
                              IsChecked="{Binding UseExternalAircraftInjectionDir, Mode=TwoWay}">
                        <TextBlock Text="{x:Static resx:Strings_Settings.ExternalAircraftInjectionCheckBoxText}"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource MaterialDesignHeadlineSmallTextBlock}" />
                    </CheckBox>
                    <TextBlock Margin="{StaticResource XSmallTopMargin}"
                               Text="{x:Static resx:Strings_Settings.ExternalAircraftInjectionDirExplanationText}"
                               TextWrapping="Wrap"
                               Style="{StaticResource MaterialDesignBodySmallTextBlock}" />
                    <common:DirectoryPicker
                                            Path="{Binding ExternalAircraftInjectionDir, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            Key="ExternalAircraftInjection"
                                            IsEnabled="{Binding UseExternalAircraftInjectionDir}"
                                            ButtonText="{x:Static resx:Strings_Settings.SelectButton}"
                                            Margin="{StaticResource XSmallTopMargin}" />

                    <CheckBox Margin="0,16,0,0"
                              Padding="0"
                              VerticalContentAlignment="Center"
                              IsChecked="{Binding UseExternalCampaignInjectionDir, Mode=TwoWay}">
                        <TextBlock Text="{x:Static resx:Strings_Settings.ExternalCampaignInjectionCheckBoxText}"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource MaterialDesignHeadlineSmallTextBlock}" />
                    </CheckBox>
                    <TextBlock Margin="{StaticResource XSmallTopMargin}"
                               Text="{x:Static resx:Strings_Settings.ExternalCampaignInjectionDirExplanationText}"
                               TextWrapping="Wrap"
                               Style="{StaticResource MaterialDesignBodySmallTextBlock}" />
                    <common:DirectoryPicker
                                            Path="{Binding ExternalCampaignInjectionDir, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            Key="ExternalCampaignInjection"
                                            IsEnabled="{Binding UseExternalCampaignInjectionDir}"
                                            ButtonText="{x:Static resx:Strings_Settings.SelectButton}"
                                            Margin="{StaticResource XSmallTopMargin}" />

                    <TextBlock Margin="{StaticResource MediumTopMargin}"
                               Text="{x:Static resx:Strings_Settings.DcsTranslationToolSectionTitle}"
                               Style="{StaticResource MaterialDesignHeadlineSmallTextBlock}" />

                    <TextBlock Margin="{StaticResource SmallTopMargin}"
                               Text="{x:Static resx:Strings_Settings.TranslateFileDirText}"
                               Style="{StaticResource MaterialDesignHeadlineSmallTextBlock}" />
                    <TextBlock Margin="{StaticResource XSmallTopMargin}"
                               Text="{x:Static resx:Strings_Settings.SourceTranslateFileDirExplanationText}"
                               TextWrapping="Wrap"
                               Style="{StaticResource MaterialDesignBodySmallTextBlock}" />
                    <common:DirectoryPicker
                                            Path="{Binding TranslateFileDir, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            Key="TranslateFile"
                                            Margin="{StaticResource XSmallTopMargin}"
                                            ButtonText="{x:Static resx:Strings_Settings.SelectButton}" />
                </StackPanel>
                <!-- About -->
                <StackPanel Margin="{StaticResource MediumTopMargin}">
                    <TextBlock Margin="{StaticResource MediumTopMargin}"
                               Style="{StaticResource MaterialDesignHeadlineMediumTextBlock}"
                               Text="{x:Static resx:Strings_Settings.AboutTitle}" />

                    <TextBlock Margin="{StaticResource XSmallTopMargin}"
                            Style="{StaticResource MaterialDesignBodyLargeTextBlock}"
                            Text="{x:Static resx:Strings_Settings.AboutText}" />
                </StackPanel>
                <!-- バージョン情報 -->
                <StackPanel Margin="{StaticResource MediumTopMargin}">
                    <TextBlock Text="{x:Static resx:Strings_Settings.VersionDescriptionTitle}"
                               Style="{StaticResource MaterialDesignHeadlineMediumTextBlock}" />
                    <TextBlock Text="{Binding VersionDescription, Mode=OneWay}" Style="{StaticResource MaterialDesignBodyLargeTextBlock}" />
                    <Button cal:Message.Attach="BrowseToReleaseLatestPage()"
                            Style="{StaticResource HyperLinkButtonStyle}">
                        <TextBlock Text="{x:Static resx:Strings_Settings.ReleaseLatestText}" TextDecorations="Underline" />
                    </Button>
                </StackPanel>
                <!-- プライバシーポリシー -->
                <StackPanel Margin="{StaticResource MediumTopMargin}">
                    <TextBlock Text="{x:Static resx:Strings_Settings.PrivacyPolicyTitle}"
                           Style="{StaticResource MaterialDesignHeadlineMediumTextBlock}" />

                    <Button cal:Message.Attach="BrowseToPrivacyStatement()"
                            Style="{StaticResource HyperLinkButtonStyle}"
                            AutomationProperties.Name="{Binding Text, ElementName=settingsPrivacyStatement}">
                        <TextBlock Text="{x:Static resx:Strings_Settings.PrivacyPolicyText}" TextDecorations="Underline" />
                    </Button>
                </StackPanel>
            </StackPanel>
        </Grid>
    </ScrollViewer>

</Page>
